config_version=5

[application]

config/name="GDEXTest"
run/main_scene="uid://uiqwuk5slaqx"
config/features=PackedStringArray("4.4", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[debug]

settings/stdout/print_fps=true

[display]

window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="GDEXTest"

[editor]

movie_writer/movie_file="D:/godot/Project/gdex/demo/Movie_Writter/a.avi"
movie_writer/disable_vsync=true

[editor_plugins]

enabled=PackedStringArray("res://addons/GdexToCS/plugin.cfg", "res://addons/MyGDEXcpp/plugin.cfg")

